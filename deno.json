{
  "tasks": {
    "dev": "deno run --allow-net --allow-env --env-file --watch main.ts",
    "start": "deno run --allow-net --allow-env --env-file main.ts",
    "test": "deno test app/"
  },
  "compilerOptions": {
    "jsx": "react-jsx",
    "jsxImportSource": "preact"
  },
  "imports": {
    "postgres": "npm:postgres@3",
    "@std/assert": "jsr:@std/assert@1",
    "preact": "npm:preact@10",
    "preact/": "npm:/preact@10/",
    "preact-render-to-string": "npm:preact-render-to-string@6"
  },
  "fmt": { "lineWidth": 100 },
  "lint": { "rules": { "exclude": ["jsx-key"] } }
}
