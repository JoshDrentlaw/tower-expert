# Local dev (docker compose up -d starts postgres on port 5433):
# DATABASE_URL=postgres://tower:changeme@localhost:5433/tower

# Production (Nucklehead) — dedicated tower DB inside chores-postgres:
# DATABASE_URL=postgres://tower:CHANGE_ME@chores-postgres:5432/tower

DATABASE_URL=postgres://tower:changeme@localhost:5433/tower

# Subpath this app is served under (matches your Caddy `handle /tower*` block).
BASE_PATH=/tower
PORT=8787
